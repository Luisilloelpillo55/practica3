{
  "name": "mi-practica",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:mi-practica": "node dist/mi-practica/server/server.mjs",
    "start:gateway": "tsx src/services/gateway/server.ts",
    "start:users": "tsx src/services/users-service/server.ts",
    "start:groups": "tsx src/services/groups-service/server.ts",
    "start:tickets": "tsx src/services/tickets-service/server.ts",
    "start:all": "concurrently \"npm run start:gateway\" \"npm run start:users\" \"npm run start:groups\" \"npm run start:tickets\" \"npm run start\"",
    "start:backend": "concurrently \"npm run start:gateway\" \"npm run start:users\" \"npm run start:groups\" \"npm run start:tickets\""
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@10.9.4",
  "dependencies": {
    "@angular/animations": "^21.1.5",
    "@angular/cdk": "^21.1.5",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/platform-server": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@angular/ssr": "^21.1.5",
    "@fastify/http-proxy": "^11.4.3",
    "@supabase/supabase-js": "^2.103.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.1.0",
    "express-http-proxy": "^2.1.2",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.18.2",
    "pg": "^8.20.0",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.5",
    "@angular/cli": "^21.1.5",
    "@angular/compiler-cli": "^21.1.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.1",
    "@types/express-http-proxy": "^1.6.7",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.17.19",
    "@types/pg": "^8.20.0",
    "concurrently": "^9.0.1",
    "jsdom": "^27.1.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
